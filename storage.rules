rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Property images ──
    // Listings and admin can upload, all signed-in staff can view
    match /properties/{imageId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Deal documents ──
    // Stored under: documents/{leadId}/{fileName}
    // CS and Finance can upload — PDF, images, Word, Excel (max 15MB)
    // All signed-in staff can read (Firestore rules scope further)
    // NO update, NO delete — permanent records
    match /documents/{leadId}/{fileName} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.size < 15 * 1024 * 1024
                    && (
                      request.resource.contentType.matches('image/.*')
                      || request.resource.contentType == 'application/pdf'
                      || request.resource.contentType == 'application/msword'
                      || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
                      || request.resource.contentType == 'application/vnd.ms-excel'
                      || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
                      || request.resource.contentType == 'application/octet-stream'
                      || request.resource.contentType == 'text/plain'
                    );

      allow update: if false; // Immutable once uploaded
      allow delete: if false; // Never deleted
    }

    // Block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
