rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ─────────────────────────────────────────────

    function isSignedIn()  { return request.auth != null; }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function userRole()    { return getUserData().role; }

    function isAdmin()    { return isSignedIn() && userRole() == 'admin'; }
    function isCEO()      { return isSignedIn() && userRole() == 'ceo'; }
    function isAgent()    { return isSignedIn() && userRole() == 'agent'; }
    function isListings() { return isSignedIn() && userRole() == 'listings'; }
    function isCS()       { return isSignedIn() && userRole() == 'cs'; }
    function isFinance()  { return isSignedIn() && userRole() == 'finance'; }

    function isAdminOrCEO()      { return isAdmin() || isCEO(); }
    function isAdminCEOFinance() { return isAdmin() || isCEO() || isFinance(); }

    // The Vine — CS has full editor access
    function isVineStaff()  { return isAdmin() || isCEO() || isFinance() || isListings() || isCS(); }
    function isVineEditor() { return isAdmin() || isFinance() || isListings() || isCS(); }


    // ─────────────────────────────────────────────
    // USERS
    // Admin manages all users.
    // Staff can read all users (needed for lookups/dropdowns).
    // Users can update their own profile but NEVER change their role.
    // Roles are permanent — only admin can change them.
    // ─────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.auth.uid == userId;

      allow update: if isAdmin()
                    || (isSignedIn()
                        && request.auth.uid == userId
                        && !request.resource.data.diff(resource.data)
                           .affectedKeys().hasAny(['role']));

      allow delete: if false;
    }


    // ─────────────────────────────────────────────
    // CLIENTS
    // All signed-in staff can read.
    // Agents, CS, Listings, Admin can create.
    // CS and Admin can edit any client.
    // Agents can edit their own clients.
    // ─────────────────────────────────────────────

    match /clients/{clientId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.createdBy == request.auth.uid
                    && (isAgent() || isCS() || isListings() || isAdmin());

      allow update: if isAdmin()
                    || isCS()
                    || (isAgent() && resource.data.createdBy == request.auth.uid);

      allow delete: if isAdmin();
    }


    // ─────────────────────────────────────────────
    // PROPERTIES
    // Everyone reads. Listings and Admin manage.
    // ─────────────────────────────────────────────

    match /properties/{propertyId} {
      allow read:   if isSignedIn();
      allow create: if isListings() || isAdmin();
      allow update: if isListings() || isAdmin();
      allow delete: if isAdmin();
    }


    // ─────────────────────────────────────────────
    // LEADS
    // Workflow:
    //   new → contacted → viewing_scheduled → viewing_completed
    //   → negotiation → closed_pending → closed_validated
    //   → no_show / rescheduled / not_interested / lost
    //
    // Who can create leads:
    //   Agent: own agent-type leads
    //   Listings: company-type leads
    //   CS: any lead type (CS interfaces clients first)
    //   Admin: any
    //
    // Who can update leads:
    //   Agent: own leads, cannot validate, cannot change agreedPrice
    //   Listings: company leads, cannot validate, cannot change agreedPrice
    //   CS: all leads (schedule viewings, update status, upload docs flag)
    //       cannot validate, cannot change agreedPrice
    //   Finance: only invoice/payment related fields
    //   CEO: all fields except status
    //   Admin: full control including validation
    // ─────────────────────────────────────────────

    match /leads/{leadId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.createdBy == request.auth.uid
                    && (
                      isAdmin()
                      || isCS()
                      || (isAgent()    && request.resource.data.leadType == 'agent')
                      || (isListings() && request.resource.data.leadType == 'company')
                    );

      allow update: if isAdmin()

                    // CEO: can update any field EXCEPT status
                    || (isCEO()
                        && !request.resource.data.diff(resource.data)
                           .affectedKeys().hasAny(['status']))

                    // Agent: own agent leads
                    // Cannot: validate, change agreedPrice or priceOverride
                    || (isAgent()
                        && resource.data.createdBy == request.auth.uid
                        && resource.data.leadType  == 'agent'
                        && request.resource.data.status != 'closed_validated'
                        && !request.resource.data.diff(resource.data)
                           .affectedKeys().hasAny(['agreedPrice', 'priceOverride']))

                    // Listings: company leads
                    // Cannot: validate, change agreedPrice or priceOverride
                    || (isListings()
                        && resource.data.leadType == 'company'
                        && request.resource.data.status != 'closed_validated'
                        && !request.resource.data.diff(resource.data)
                           .affectedKeys().hasAny(['agreedPrice', 'priceOverride']))

                    // CS: all leads — schedule viewings, update status, add notes
                    // Cannot: validate deals, change agreedPrice or priceOverride
                    || (isCS()
                        && request.resource.data.status != 'closed_validated'
                        && !request.resource.data.diff(resource.data)
                           .affectedKeys().hasAny(['agreedPrice', 'priceOverride']))

                    // Finance: can only update invoice and payment tracking fields
                    || (isFinance()
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly([
                             'invoiceIssued', 'invoiceId', 'paymentPlan',
                             'agreedPrice', 'currency', 'totalPaid', 'balanceDue',
                             'paymentPlanSetBy', 'paymentPlanSetAt', 'updatedAt'
                           ]));

      allow delete: if isAdmin();
    }


    // ─────────────────────────────────────────────
    // LEAD — INVOICES SUBCOLLECTION
    // Finance, Admin, CEO can issue and update invoices.
    // All signed-in staff can read.
    // ─────────────────────────────────────────────

    match /leads/{leadId}/invoices/{invoiceId} {
      allow read: if isSignedIn();

      allow create: if isAdminCEOFinance()
                    && request.resource.data.issuedBy == request.auth.uid;

      allow update: if isAdminCEOFinance();
      allow delete: if isAdmin();
    }


    // ─────────────────────────────────────────────
    // LEAD — LEDGER SUBCOLLECTION
    // Finance and Admin record payment entries.
    // All signed-in staff can read.
    // ─────────────────────────────────────────────

    match /leads/{leadId}/ledger/{entryId} {
      allow read: if isSignedIn();

      allow create: if (isFinance() || isAdmin())
                    && request.resource.data.createdBy == request.auth.uid;

      allow update: if isFinance() || isAdmin();
      allow delete: if isAdmin();
    }


    // ─────────────────────────────────────────────
    // LEAD — RECEIPTS SUBCOLLECTION
    // Finance generates receipts per ledger entry.
    // All signed-in staff can read.
    // ─────────────────────────────────────────────

    match /leads/{leadId}/receipts/{receiptId} {
      allow read: if isSignedIn();

      allow create: if (isFinance() || isAdmin())
                    && request.resource.data.generatedBy == request.auth.uid;

      allow update: if isFinance() || isAdmin();
      allow delete: if isAdmin();
    }


    // ─────────────────────────────────────────────
    // LEAD — DOCUMENTS SUBCOLLECTION
    // CS uploads: purchase_agreement, land_title
    // Finance uploads: final_receipt, payment_receipt
    // Admin can upload anything.
    // IMMUTABLE — no updates, no deletes ever.
    // All signed-in staff can read.
    // ─────────────────────────────────────────────

    match /leads/{leadId}/documents/{docId} {
      allow read: if isSignedIn();

      allow create: if (isCS() || isFinance() || isAdmin())
                    && request.resource.data.uploadedBy == request.auth.uid;

      allow update: if false;
      allow delete: if false;
    }


    // ─────────────────────────────────────────────
    // THE VINE — BOOKINGS
    // CS has FULL access — CS is the primary operator of The Vine.
    // Finance, Listings, Admin can also create and edit.
    // CEO can read only.
    // Only Admin can delete.
    // ─────────────────────────────────────────────

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && isVineStaff();

      allow create: if isVineEditor()
                    && request.resource.data.createdBy == request.auth.uid;

      allow update: if isVineEditor();
      allow delete: if isAdmin();
    }


    // ─────────────────────────────────────────────
    // THE VINE — BOOKING INVOICES SUBCOLLECTION
    // CS, Finance, Listings, Admin can create and update.
    // All Vine staff can read.
    // ─────────────────────────────────────────────

    match /bookings/{bookingId}/invoices/{invoiceId} {
      allow read: if isSignedIn() && isVineStaff();

      allow create: if isVineEditor();

      allow update: if isVineEditor();
      allow delete: if isAdmin();
    }


    // ─────────────────────────────────────────────
    // THE VINE — BOOKING PAYMENTS SUBCOLLECTION
    // CS, Finance, Listings, Admin record payments.
    // All Vine staff can read.
    // ─────────────────────────────────────────────

    match /bookings/{bookingId}/payments/{paymentId} {
      allow read: if isSignedIn() && isVineStaff();

      allow create: if isVineEditor();

      allow update: if isVineEditor();
      allow delete: if isAdmin();
    }


    // ─────────────────────────────────────────────
    // THE VINE — BOOKING RECEIPTS SUBCOLLECTION
    // CS, Finance, Listings, Admin generate receipts.
    // All Vine staff can read.
    // ─────────────────────────────────────────────

    match /bookings/{bookingId}/receipts/{receiptId} {
      allow read: if isSignedIn() && isVineStaff();

      allow create: if isVineEditor();

      allow update: if isVineEditor();
      allow delete: if isAdmin();
    }


    // ─────────────────────────────────────────────
    // MESSAGES (staff announcement board)
    // All signed-in staff can read and post.
    // Staff can delete their own messages. Admin can delete any.
    // ─────────────────────────────────────────────

    match /messages/{messageId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.postedBy == request.auth.uid;

      allow update: if isAdmin()
                    || (isSignedIn() && resource.data.postedBy == request.auth.uid);

      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.postedBy == request.auth.uid);
    }


    // ─────────────────────────────────────────────
    // NOTIFICATIONS
    // Each user reads only their own notifications.
    // Any signed-in user can create (e.g. deal closed → notify admin).
    // Users can only mark their own as read (isRead field only).
    // ─────────────────────────────────────────────

    match /notifications/{notifId} {
      allow read: if isSignedIn()
                  && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn();

      allow update: if isSignedIn()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data)
                       .affectedKeys().hasOnly(['isRead']);

      allow delete: if false;
    }


    // ─────────────────────────────────────────────
    // INQUIRIES (public form submissions)
    // Anyone can submit — public inquiry form requires no auth.
    // Admin, CEO, CS can read and manage inquiries.
    // ─────────────────────────────────────────────

    match /inquiries/{inquiryId} {
      allow create: if true;

      allow read: if isSignedIn()
                  && (isAdmin() || isCEO() || isCS());

      allow update: if isAdmin() || isCS();
      allow delete: if false;
    }


    // ─────────────────────────────────────────────
    // INFLUENCERS
    // All signed-in staff can read.
    // Admin manages influencer profiles.
    // ─────────────────────────────────────────────

    match /influencers/{influencerId} {
      allow read:   if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }


    // ─────────────────────────────────────────────
    // INFLUENCER STATS (public aggregate counts)
    // Fully public read and write — the public stats page
    // and the public inquiry form both operate without auth.
    // Admin can delete stale entries.
    // ─────────────────────────────────────────────

    match /influencer_stats/{refCode} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

  }
}